<Project Sdk="Microsoft.NET.Sdk;Dalamud.NET.Sdk/14.0.2">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AssemblyName>SaddlebagExchange</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Author>Saddlebag Exchange</Author>
    <Name>Saddlebag Exchange</Name>
    <Punchline>Marketboard analytics for FFXIV</Punchline>
    <Description>Advanced marketboard tools and cross-world arbitrage scanning.</Description>
    <InternalName>SaddlebagExchange</InternalName>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <DalamudApiLevel>14</DalamudApiLevel>
    <LoadRequiredState>0</LoadRequiredState>
  </PropertyGroup>

  <!-- Use host's ImGui (single cimgui). Do NOT use ImGui.NET - it loads a second cimgui from Temp and crashes. -->
  <!-- In CI (GITHUB_ACTIONS) we omit this so the SDK provides ImGui; locally we use the host DLL. -->
  <ItemGroup Condition=" '$(GITHUB_ACTIONS)' != 'true' ">
    <Reference Include="Dalamud.Bindings.ImGui">
      <HintPath>$(USERPROFILE)\AppData\Roaming\XIVLauncher\addon\Hooks\14.0.4.1\Dalamud.Bindings.ImGui.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- Icon shown in /xlplugins for dev plugins (icon.png next to DLL) -->
  <ItemGroup>
    <Content Include="Assets\icon.png" CopyToOutputDirectory="PreserveNewest" Link="icon.png" />
  </ItemGroup>

  <!-- In CI there is no local Dalamud install; skip the SDK's path check so the build can run. -->
  <Target Name="EnsureDalamudLibPathExists" BeforeTargets="BeforeBuild">
    <Error Text="Dalamud.NET.Sdk: Dalamud installation not found at $(DalamudLibPath)" Condition="!Exists('$(DalamudLibPath)') and '$(GITHUB_ACTIONS)' != 'true'" />
  </Target>

  <!-- After build: (1) copy to bin\Debug so "other path" works, (2) copy to XIVLauncher devPlugins -->
  <Target Name="CopyToDevPlugins" AfterTargets="Build" Condition=" '$(Configuration)' == 'Debug' ">
    <PropertyGroup>
      <_DevPluginsDir>$(MSBuildProjectDirectory)\..\..\SaddlebagExchange</_DevPluginsDir>
      <_BinDebugDir>$(MSBuildProjectDirectory)\bin\$(Configuration)</_BinDebugDir>
    </PropertyGroup>
    <ItemGroup>
      <_CopyFiles Include="$(OutputPath)SaddlebagExchange.dll" />
      <_CopyFiles Include="$(OutputPath)icon.png" />
      <_CopyFiles Include="$(MSBuildProjectDirectory)\manifest.json" Condition=" Exists('$(MSBuildProjectDirectory)\manifest.json') " />
    </ItemGroup>
    <!-- Copy to bin\Debug so adding "...\SaddlebagExchange\bin\Debug\SaddlebagExchange.dll" as dev path works -->
    <MakeDir Directories="$(_BinDebugDir)" Condition=" !Exists('$(_BinDebugDir)') " />
    <Copy SourceFiles="@(_CopyFiles)" DestinationFolder="$(_BinDebugDir)" SkipUnchangedFiles="true" />
    <!-- Copy to XIVLauncher devPlugins folder -->
    <MakeDir Directories="$(_DevPluginsDir)" Condition=" !Exists('$(_DevPluginsDir)') " />
    <Copy SourceFiles="@(_CopyFiles)" DestinationFolder="$(_DevPluginsDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
